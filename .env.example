# ─────────────────────────────────────────────────────────────────
# Career-Trek AI – Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your real values.
# Never commit `.env` to version control.
# ─────────────────────────────────────────────────────────────────

# IBM Cloud IAM API Key
# Generate one at: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_cloud_api_key_here

# Full URL of your IBM watsonx Orchestrate Agent endpoint
# Example: https://us-south.ml.cloud.ibm.com/ml/v4/deployments/<deployment-id>/predictions
AGENT_URL=https://<region>.ml.cloud.ibm.com/ml/v4/deployments/<deployment-id>/predictions

# Unique identifier (UID) of your deployed Orchestrate Agent
AGENT_UID=your_agent_uid_here
